{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/el-chapo",
      "destination": "/el-chapo.html"
    },
    {
      "source": "/el-chapo/:path*",
      "destination": "/el-chapo.html"
    },
    {
      "source": "/ipa/:id",
      "destination": "/"
    },
    {
      "source": "/apps",
      "destination": "/"
    },
    {
      "source": "/games",
      "destination": "/"
    },
    {
      "source": "/updates/apps",
      "destination": "/"
    },
    {
      "source": "/updates/games",
      "destination": "/"
    },
    {
      "source": "/search",
      "destination": "/"
    },
    {
      "source": "/admin-api",
      "destination": "/"
    }
  ]
}
